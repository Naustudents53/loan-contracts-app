<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <h2 class="page-title mb-4 animate-in"><i class="bi bi-pencil"></i> Editar Contrato #<%= contract.id %></h2>

    <form action="/contracts/<%= contract.id %>?_method=PUT" method="POST" enctype="multipart/form-data">
      <div class="glass-card mb-4 animate-in delay-1">
        <div class="card-header accent"><i class="bi bi-person"></i> Datos del Cliente</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="client_name" class="form-label-dark">Nombre Completo *</label>
              <input type="text" class="form-control form-control-dark" id="client_name" name="client_name" required value="<%= contract.client_name %>">
            </div>
            <div class="col-md-6">
              <label for="client_cedula" class="form-label-dark">Cedula *</label>
              <input type="text" class="form-control form-control-dark" id="client_cedula" name="client_cedula" required value="<%= contract.client_cedula %>">
            </div>
            <div class="col-md-6">
              <label for="client_phone" class="form-label-dark">Telefono</label>
              <input type="text" class="form-control form-control-dark" id="client_phone" name="client_phone" value="<%= contract.client_phone || '' %>">
            </div>
            <div class="col-md-6">
              <label for="client_address" class="form-label-dark">Direccion</label>
              <input type="text" class="form-control form-control-dark" id="client_address" name="client_address" value="<%= contract.client_address || '' %>">
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card mb-4 animate-in delay-2">
        <div class="card-header success-header"><i class="bi bi-cash-stack"></i> Datos del Prestamo</div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="prestamo" class="form-label-dark">Monto del Prestamo ($) *</label>
              <input type="number" step="0.01" min="0" class="form-control form-control-dark" id="prestamo" name="prestamo" required value="<%= contract.prestamo %>">
            </div>
            <div class="col-md-6">
              <label for="precio" class="form-label-dark">Precio / Interes (%) *</label>
              <input type="number" step="0.01" min="0" class="form-control form-control-dark" id="precio" name="precio" required value="<%= contract.precio %>">
            </div>
            <div class="col-md-6">
              <label for="cuota" class="form-label-dark">Cuota ($) *</label>
              <input type="number" step="0.01" min="0" class="form-control form-control-dark" id="cuota" name="cuota" required value="<%= contract.cuota %>">
            </div>
            <div class="col-md-6">
              <label for="deuda_total" class="form-label-dark">Deuda Total ($) *</label>
              <input type="number" step="0.01" min="0" class="form-control form-control-dark" id="deuda_total" name="deuda_total" required value="<%= contract.deuda_total %>">
            </div>
            <div class="col-md-6">
              <label for="confianza" class="form-label-dark">Nivel de Confianza *</label>
              <select class="form-select form-select-dark" id="confianza" name="confianza" required>
                <option value="Alta" <%= contract.confianza === 'Alta' ? 'selected' : '' %>>Alta</option>
                <option value="Media" <%= contract.confianza === 'Media' ? 'selected' : '' %>>Media</option>
                <option value="Baja" <%= contract.confianza === 'Baja' ? 'selected' : '' %>>Baja</option>
              </select>
            </div>
            <div class="col-12">
              <label for="loan_contract_pdf" class="form-label-dark">Reemplazar Contrato del Prestamo (PDF)</label>
              <input type="file" class="form-control form-control-dark" id="loan_contract_pdf" name="loan_contract_pdf" accept="application/pdf,.pdf">
              <% if (contract.contract_pdf_path) { %>
                <small style="color: var(--text-muted); display: block; margin-top: 0.4rem;">
                  PDF actual:
                  <a href="<%= contract.contract_pdf_path %>" target="_blank" rel="noopener"><%= contract.contract_pdf_original_name || 'Ver contrato actual' %></a>
                </small>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card mb-4 animate-in delay-3">
        <div class="card-header"><i class="bi bi-journal-text"></i> Notas</div>
        <div class="card-body">
          <textarea class="form-control form-control-dark" id="notes" name="notes" rows="3"><%= contract.notes || '' %></textarea>
        </div>
      </div>

      <div class="d-flex gap-3 animate-in delay-3">
        <button type="submit" class="btn btn-accent btn-lg">
          <i class="bi bi-check-lg"></i> Guardar Cambios
        </button>
        <a href="/contracts/<%= contract.id %>" class="btn btn-glass btn-lg">Cancelar</a>
      </div>
    </form>
  </div>
</div>

<script>
  const prestamoEl = document.getElementById('prestamo');
  const precioEl = document.getElementById('precio');
  const deudaEl = document.getElementById('deuda_total');

  function calcDeuda() {
    const p = parseFloat(prestamoEl.value) || 0;
    const r = parseFloat(precioEl.value) || 0;
    deudaEl.value = (p + (p * r / 100)).toFixed(2);
  }

  prestamoEl.addEventListener('input', calcDeuda);
  precioEl.addEventListener('input', calcDeuda);
</script>

<%- include('../partials/footer') %>

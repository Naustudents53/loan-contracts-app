<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4 animate-in">
      <h2 class="page-title"><i class="bi bi-file-earmark-text"></i> Contrato #<%= contract.id %></h2>
      <div class="d-flex gap-2">
        <% if (contract.status !== 'signed') { %>
          <a href="/contracts/<%= contract.id %>/edit" class="btn btn-warning-glass">
            <i class="bi bi-pencil"></i> Editar
          </a>
        <% } %>
        <a href="/contracts" class="btn btn-glass">
          <i class="bi bi-arrow-left"></i> Volver
        </a>
      </div>
    </div>

    <!-- Estado -->
    <div class="status-banner <%= contract.status === 'signed' ? 'signed' : 'pending' %> mb-4 animate-in delay-1">
      <% if (contract.status === 'signed') { %>
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div>
          <strong>Contrato Firmado</strong>
          <br><small style="opacity:0.8">Firmado el: <%= new Date(contract.signed_at).toLocaleString('es-DO') %></small>
        </div>
      <% } else { %>
        <i class="bi bi-clock-fill fs-4"></i>
        <div><strong>Pendiente de Firma</strong></div>
      <% } %>
    </div>

    <!-- Link de Firma -->
    <% if (contract.status !== 'signed') { %>
      <div class="link-box mb-4 animate-in delay-1">
        <div class="link-label"><i class="bi bi-link-45deg"></i> Link de Firma para el Cliente</div>
        <div class="input-group">
          <input type="text" class="form-control" id="signing-link" readonly
            value="<%= baseUrl %>/sign/<%= contract.signing_token %>">
          <button class="btn btn-accent" type="button" id="copy-link-btn" onclick="copyLink()">
            <i class="bi bi-clipboard"></i> Copiar
          </button>
        </div>
        <small style="color: var(--text-muted); margin-top: 0.5rem; display: block;">Comparte este link con el cliente para que firme el contrato.</small>
      </div>
    <% } %>

    <!-- Documentos -->
    <div class="glass-card mb-4 animate-in delay-1">
      <div class="card-header"><i class="bi bi-filetype-pdf"></i> Documentos del Prestamo</div>
      <div class="card-body d-flex flex-wrap gap-2 align-items-center">
        <% if (contract.contract_pdf_path) { %>
          <a href="<%= contract.contract_pdf_path %>" target="_blank" rel="noopener" class="btn btn-glass btn-sm">
            <i class="bi bi-file-earmark-pdf"></i> Ver Contrato Base
          </a>
        <% } else { %>
          <span style="color: var(--warning);">Este prestamo no tiene contrato PDF cargado.</span>
        <% } %>

        <% if (contract.signed_pdf_path) { %>
          <a href="<%= contract.signed_pdf_path %>" target="_blank" rel="noopener" class="btn btn-success-glass btn-sm">
            <i class="bi bi-check2-square"></i> Ver Contrato Firmado
          </a>
        <% } %>
      </div>
    </div>

    <!-- Nivel de Prestamo + Progreso de Cuotas -->
    <div class="glass-card mb-4 animate-in delay-1">
      <div class="card-header"><i class="bi bi-bar-chart-line"></i> Estado del Prestamo</div>
      <div class="card-body">
        <div class="row align-items-center">
          <!-- Nivel de Prestamo -->
          <div class="col-md-4 text-center mb-3 mb-md-0">
            <div class="stat-label">Nivel del Cliente</div>
            <div class="mt-2">
              <% if (nivelPrestamo.color === 'accent') { %>
                <span class="badge-glow badge-accent" style="font-size: 1rem; padding: 0.5rem 1.2rem;">
              <% } else if (nivelPrestamo.color === 'success') { %>
                <span class="badge-glow badge-success" style="font-size: 1rem; padding: 0.5rem 1.2rem;">
              <% } else if (nivelPrestamo.color === 'warning') { %>
                <span class="badge-glow badge-warning" style="font-size: 1rem; padding: 0.5rem 1.2rem;">
              <% } else { %>
                <span class="badge-glow badge-muted" style="font-size: 1rem; padding: 0.5rem 1.2rem;">
              <% } %>
                <i class="bi bi-<%= nivelPrestamo.icon %>"></i> <%= nivelPrestamo.nivel %>
              </span>
            </div>
            <small style="color: var(--text-muted); display: block; margin-top: 0.4rem; font-size: 0.75rem"><%= nivelPrestamo.desc %></small>
          </div>
          <!-- Cuotas -->
          <div class="col-md-8">
            <div class="row text-center mb-3">
              <div class="col-4">
                <div class="stat-label">Cuotas Totales</div>
                <div class="stat-value mt-1"><%= contract.cuotas_totales %></div>
              </div>
              <div class="col-4">
                <div class="stat-label">Realizadas</div>
                <div class="stat-value mt-1" style="color: var(--success)"><%= contract.cuotas_realizadas %></div>
              </div>
              <div class="col-4">
                <div class="stat-label">Restantes</div>
                <div class="stat-value mt-1" style="color: var(--warning)"><%= contract.cuotas_restantes %></div>
              </div>
            </div>
            <!-- Barra de progreso -->
            <div class="progress-bar-container">
              <div class="progress-bar-track">
                <div class="progress-bar-fill" style="width: <%= contract.progreso %>%"></div>
              </div>
              <div class="d-flex justify-content-between mt-1">
                <small style="color: var(--text-muted)"><%= contract.progreso %>% completado</small>
                <small style="color: var(--text-muted)">Saldo: $<%= Number(contract.saldo_pendiente).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></small>
              </div>
            </div>
            <% if (contract.cuotas_restantes > 0) { %>
              <form action="/contracts/<%= contract.id %>/pay" method="POST" class="mt-3 text-center"
                onsubmit="return confirm('Registrar pago de cuota #<%= contract.cuotas_realizadas + 1 %>?')">
                <button type="submit" class="btn btn-success-glass">
                  <i class="bi bi-plus-circle"></i> Registrar Pago de Cuota
                </button>
              </form>
            <% } else if (contract.cuotas_totales > 0) { %>
              <div class="text-center mt-3">
                <span class="badge-glow badge-success" style="font-size: 0.85rem"><i class="bi bi-trophy"></i> Prestamo Liquidado</span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Datos del Cliente -->
    <div class="glass-card mb-4 animate-in delay-2">
      <div class="card-header accent"><i class="bi bi-person"></i> Datos del Cliente</div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-6 mb-3">
            <div class="stat-label">Nombre</div>
            <div class="mt-1"><%= contract.client_name %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="stat-label">Cedula</div>
            <div class="mt-1"><%= contract.client_cedula %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="stat-label">Telefono</div>
            <div class="mt-1"><%= contract.client_phone || 'N/A' %></div>
          </div>
          <div class="col-md-6 mb-3">
            <div class="stat-label">Direccion</div>
            <div class="mt-1"><%= contract.client_address || 'N/A' %></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Datos del Prestamo -->
    <div class="glass-card mb-4 animate-in delay-2">
      <div class="card-header success-header"><i class="bi bi-cash-stack"></i> Datos del Prestamo</div>
      <div class="card-body">
        <div class="row text-center">
          <div class="col-6 col-md-4 mb-4">
            <div class="stat-label">Prestamo</div>
            <div class="stat-value mt-1">$<%= Number(contract.prestamo).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></div>
          </div>
          <div class="col-6 col-md-4 mb-4">
            <div class="stat-label">Interes</div>
            <div class="stat-value mt-1"><%= contract.precio %>%</div>
          </div>
          <div class="col-6 col-md-4 mb-4">
            <div class="stat-label">Cuota</div>
            <div class="stat-value mt-1">$<%= Number(contract.cuota).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></div>
          </div>
          <div class="col-6 col-md-6 mb-3">
            <div class="stat-label">Deuda Total</div>
            <div class="stat-value mt-1" style="color: var(--danger)">$<%= Number(contract.deuda_total).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></div>
          </div>
          <div class="col-12 col-md-6 mb-3">
            <div class="stat-label">Confianza</div>
            <div class="mt-2">
              <% if (contract.confianza === 'Alta') { %>
                <span class="badge-glow badge-success" style="font-size:0.9rem">Alta</span>
              <% } else if (contract.confianza === 'Media') { %>
                <span class="badge-glow badge-warning" style="font-size:0.9rem">Media</span>
              <% } else { %>
                <span class="badge-glow badge-danger" style="font-size:0.9rem">Baja</span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Notas -->
    <% if (contract.notes) { %>
      <div class="glass-card mb-4 animate-in delay-3">
        <div class="card-header"><i class="bi bi-journal-text"></i> Notas</div>
        <div class="card-body" style="color: var(--text-secondary)"><%= contract.notes %></div>
      </div>
    <% } %>

    <!-- Firma -->
    <% if (contract.status === 'signed' && contract.signature_data) { %>
      <div class="glass-card mb-4 animate-in delay-3">
        <div class="card-header success-header"><i class="bi bi-pen"></i> Firma del Cliente</div>
        <div class="card-body text-center">
          <img src="<%= contract.signature_data %>" alt="Firma del cliente" class="signature-preview img-fluid">
        </div>
      </div>
    <% } %>

    <small style="color: var(--text-muted)">Creado: <%= new Date(contract.created_at).toLocaleString('es-DO') %></small>
  </div>
</div>

<script>
function copyLink() {
  const input = document.getElementById('signing-link');
  navigator.clipboard.writeText(input.value).then(() => {
    const btn = document.getElementById('copy-link-btn');
    btn.innerHTML = '<i class="bi bi-check-lg"></i> Copiado!';
    setTimeout(() => {
      btn.innerHTML = '<i class="bi bi-clipboard"></i> Copiar';
    }, 2000);
  });
}
</script>

<%- include('../partials/footer') %>

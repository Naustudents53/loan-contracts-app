<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4 animate-in">
  <h2 class="page-title"><i class="bi bi-grid-1x2"></i> Contratos</h2>
  <a href="/contracts/new" class="btn btn-accent">
    <i class="bi bi-plus-lg"></i> Nuevo Contrato
  </a>
</div>

<!-- Filtros -->
<div class="glass-card mb-4 animate-in delay-1">
  <div class="card-body">
    <form method="GET" action="/contracts" class="row g-3 align-items-end">
      <div class="col-md-5">
        <label class="form-label-dark">Buscar cliente</label>
        <input type="text" name="search" class="form-control form-control-dark" placeholder="Nombre del cliente..."
          value="<%= typeof search !== 'undefined' ? search : '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label-dark">Estado</label>
        <select name="status" class="form-select form-select-dark">
          <option value="">Todos</option>
          <option value="pending" <%= typeof filterStatus !== 'undefined' && filterStatus === 'pending' ? 'selected' : '' %>>Pendiente</option>
          <option value="signed" <%= typeof filterStatus !== 'undefined' && filterStatus === 'signed' ? 'selected' : '' %>>Firmado</option>
        </select>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-accent-outline w-100">
          <i class="bi bi-search"></i> Filtrar
        </button>
      </div>
    </form>
  </div>
</div>

<% if (contracts.length === 0) { %>
  <div class="glass-card animate-in delay-2">
    <div class="empty-state">
      <i class="bi bi-inbox"></i>
      <p class="lead">No hay contratos registrados</p>
      <a href="/contracts/new" class="btn btn-accent mt-2">Crear primer contrato</a>
    </div>
  </div>
<% } else { %>

  <!-- Mobile: Cards -->
  <div class="d-lg-none">
    <% contracts.forEach((c, i) => { %>
      <div class="glass-card mb-3 animate-in delay-<%= Math.min(i + 1, 3) %>">
        <div class="card-body">
          <!-- Header row -->
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h6 class="mb-1" style="color: var(--text-primary)"><%= c.client_name %></h6>
              <small style="color: var(--text-muted)"><%= c.client_cedula %></small>
            </div>
            <div class="d-flex gap-1 align-items-center">
              <% if (c.status === 'signed') { %>
                <span class="badge-glow badge-success"><i class="bi bi-check-circle"></i> Firmado</span>
              <% } else { %>
                <span class="badge-glow badge-muted"><i class="bi bi-clock"></i> Pendiente</span>
              <% } %>
            </div>
          </div>

          <!-- Stats grid -->
          <div class="row g-2 mb-3">
            <div class="col-4 text-center">
              <div class="stat-label" style="font-size:0.65rem">Prestamo</div>
              <div style="color: var(--text-primary); font-weight: 600; font-size: 0.9rem">$<%= Number(c.prestamo).toLocaleString('es-DO', {minimumFractionDigits: 0}) %></div>
            </div>
            <div class="col-4 text-center">
              <div class="stat-label" style="font-size:0.65rem">Cuota</div>
              <div style="color: var(--text-primary); font-weight: 600; font-size: 0.9rem">$<%= Number(c.cuota).toLocaleString('es-DO', {minimumFractionDigits: 0}) %></div>
            </div>
            <div class="col-4 text-center">
              <div class="stat-label" style="font-size:0.65rem">Deuda Total</div>
              <div style="color: var(--danger); font-weight: 700; font-size: 0.9rem">$<%= Number(c.deuda_total).toLocaleString('es-DO', {minimumFractionDigits: 0}) %></div>
            </div>
          </div>

          <!-- Cuotas progress -->
          <div class="d-flex align-items-center gap-3 mb-3">
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between mb-1">
                <small style="color: var(--text-secondary)">Cuotas: <%= c.cuotas_realizadas %>/<%= c.cuotas_totales %></small>
                <small style="color: var(--text-muted)"><%= c.progreso %>%</small>
              </div>
              <div class="progress-bar-track" style="height: 5px">
                <div class="progress-bar-fill" style="width: <%= c.progreso %>%"></div>
              </div>
            </div>
            <% if (c.confianza === 'Alta') { %>
              <span class="badge-glow badge-success"><%= c.confianza %></span>
            <% } else if (c.confianza === 'Media') { %>
              <span class="badge-glow badge-warning"><%= c.confianza %></span>
            <% } else { %>
              <span class="badge-glow badge-danger"><%= c.confianza %></span>
            <% } %>
          </div>

          <!-- Actions -->
          <div class="d-flex gap-2">
            <a href="/contracts/<%= c.id %>" class="btn btn-accent-outline btn-sm flex-grow-1">
              <i class="bi bi-eye"></i> Ver
            </a>
            <% if (c.status !== 'signed') { %>
              <a href="/contracts/<%= c.id %>/edit" class="btn btn-warning-glass btn-sm">
                <i class="bi bi-pencil"></i>
              </a>
            <% } %>
            <button type="button" class="btn btn-danger-glass btn-sm" title="Eliminar"
              onclick="if(confirm('Estas seguro de eliminar este contrato?')) document.getElementById('delete-m-<%= c.id %>').submit()">
              <i class="bi bi-trash"></i>
            </button>
            <form id="delete-m-<%= c.id %>" action="/contracts/<%= c.id %>?_method=DELETE" method="POST" class="d-none"></form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Desktop: Table -->
  <div class="glass-card animate-in delay-2 d-none d-lg-block">
    <div class="table-responsive">
      <table class="table table-dark-custom mb-0">
        <thead>
          <tr>
            <th>#</th>
            <th>Cliente</th>
            <th>Cedula</th>
            <th>Prestamo</th>
            <th>Cuota</th>
            <th>Deuda Total</th>
            <th>Cuotas</th>
            <th>Confianza</th>
            <th>Estado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% contracts.forEach(c => { %>
            <tr>
              <td><%= c.id %></td>
              <td><strong><%= c.client_name %></strong></td>
              <td><%= c.client_cedula %></td>
              <td>$<%= Number(c.prestamo).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></td>
              <td>$<%= Number(c.cuota).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></td>
              <td class="fw-bold">$<%= Number(c.deuda_total).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></td>
              <td>
                <div style="min-width: 80px">
                  <small style="color: var(--text-secondary)"><%= c.cuotas_realizadas %>/<%= c.cuotas_totales %></small>
                  <div class="progress-bar-track mt-1" style="height: 4px">
                    <div class="progress-bar-fill" style="width: <%= c.progreso %>%"></div>
                  </div>
                </div>
              </td>
              <td>
                <% if (c.confianza === 'Alta') { %>
                  <span class="badge-glow badge-success">Alta</span>
                <% } else if (c.confianza === 'Media') { %>
                  <span class="badge-glow badge-warning">Media</span>
                <% } else { %>
                  <span class="badge-glow badge-danger">Baja</span>
                <% } %>
              </td>
              <td>
                <% if (c.status === 'signed') { %>
                  <span class="badge-glow badge-success"><i class="bi bi-check-circle"></i> Firmado</span>
                <% } else { %>
                  <span class="badge-glow badge-muted"><i class="bi bi-clock"></i> Pendiente</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/contracts/<%= c.id %>" class="btn btn-glass btn-sm" title="Ver">
                    <i class="bi bi-eye"></i>
                  </a>
                  <% if (c.status !== 'signed') { %>
                    <a href="/contracts/<%= c.id %>/edit" class="btn btn-warning-glass btn-sm" title="Editar">
                      <i class="bi bi-pencil"></i>
                    </a>
                  <% } %>
                  <button type="button" class="btn btn-danger-glass btn-sm" title="Eliminar"
                    onclick="if(confirm('Estas seguro de eliminar este contrato?')) document.getElementById('delete-<%= c.id %>').submit()">
                    <i class="bi bi-trash"></i>
                  </button>
                </div>
                <form id="delete-<%= c.id %>" action="/contracts/<%= c.id %>?_method=DELETE" method="POST" class="d-none"></form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>

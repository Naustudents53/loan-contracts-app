<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contrato Firmado</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Sora:wght@500;600;700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-5 text-center">
        <div class="glass-card state-card animate-in" role="status" aria-live="polite">
          <div class="state-icon state-icon-success">
            <i class="bi bi-check-circle-fill"></i>
          </div>
          <h2 class="page-title text-success-title">Firmado</h2>
          <p class="state-copy">
            Gracias, <strong class="text-primary-strong"><%= contract.client_name %></strong>.<br>
            Su contrato ha sido firmado exitosamente.
          </p>
          <hr class="state-divider">
          <div class="text-start state-summary">
            <div class="state-row">
              <span class="stat-label">Prestamo</span>
              <span>$<%= Number(contract.prestamo).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></span>
            </div>
            <div class="state-row">
              <span class="stat-label">Cuota</span>
              <span>$<%= Number(contract.cuota).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></span>
            </div>
            <div class="state-row">
              <span class="stat-label">Deuda Total</span>
              <span class="text-danger-strong">$<%= Number(contract.deuda_total).toLocaleString('es-DO', {minimumFractionDigits: 2}) %></span>
            </div>
            <div class="state-row">
              <span class="stat-label">Fecha</span>
              <span><%= new Date(contract.signed_at).toLocaleString('es-DO') %></span>
            </div>
          </div>
          <% if (contract.signed_pdf_path) { %>
            <div class="mt-4">
              <a href="/sign/<%= contract.signing_token %>/pdf" target="_blank" rel="noopener" class="btn btn-success-glass">
                <i class="bi bi-file-earmark-arrow-down"></i> Descargar Contrato Firmado
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
